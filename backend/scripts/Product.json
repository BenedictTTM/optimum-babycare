[{"id":1,"title":"Gentle Baby Care Essentials Set","description":"A premium collection of baby care essentials including gentle body wash, moisturizing lotion, and nourishing baby oil. Formulated with natural ingredients, free from parabens, sulfates, and artificial fragrances. Dermatologist tested and hypoallergenic — safe for your baby's delicate skin from day one.","imageUrl":["https://images.unsplash.com/photo-1716625300692-8d5f0341b1c5?w=600&auto=format&fit=crop&q=60&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxzZWFyY2h8N3x8YmFieSUyMGNhcmUlMjBwcm9kdWN0cyUyMHdoaXRlJTIwYmFja2dyb3VuZHxlbnwwfDF8MHx8fDA%3D"],"category":"Baby Care","originalPrice":85,"discountedPrice":76.5,"stock":25,"isActive":true,"isSold":false,"condition":"new","tags":["gentle","baby","care","essentials","set"],"views":3,"createdAt":"2026-04-02 10:58:09.986","updatedAt":"2026-04-16 14:28:18.456","averageRating":0,"totalReviews":0,"lastRatingUpdate":null,"userId":1,"searchText":null,"searchVector":null,"categoryId":1},{"id":2,"title":"Premium Leather High-Top Sneakers","description":"Crafted from genuine full-grain leather, these high-top sneakers combine street style with premium comfort. Featuring cushioned insoles, reinforced stitching, and a durable rubber outsole. Perfect for everyday wear — they break in quickly and only get better with age.","imageUrl":["https://images.unsplash.com/photo-1600185365483-26d7a4cc7519"],"category":"Footwear","originalPrice":220,"discountedPrice":198,"stock":15,"isActive":true,"isSold":false,"condition":"new","tags":["premium","leather","hightop","sneakers"],"views":3,"createdAt":"2026-04-02 10:58:14.015","updatedAt":"2026-04-16 14:28:18.249","averageRating":0,"totalReviews":0,"lastRatingUpdate":null,"userId":1,"searchText":null,"searchVector":null,"categoryId":2},{"id":3,"title":"Organic Baby Skincare Bundle","description":"A curated set of organic baby skincare products featuring a gentle cleanser, soothing diaper cream, and a lightweight daily moisturizer. Made with ce